{
  "name": "programming-language-graph",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run seo:generate && tsc && vite build",
    "preview": "vite preview",
    "type-check": "tsc --noEmit",
    "analyze": "tsx scripts/analyzeDataset.ts",
    "analyze:v4": "tsx scripts/analyzeDataset.ts dataset/v4/lineage_v4.json",
    "analyze:v5": "tsx scripts/analyzeDataset.ts dataset/v5/lineage_v5.json",
    "dataset:v5": "tsx scripts/generateV5Dataset.ts",
    "logos:wikimedia": "tsx scripts/harvestWikimediaLogos.ts",
    "seo:generate": "tsx scripts/generateSeoPages.ts && tsx scripts/generateSitemap.ts && tsx scripts/generateLlmsTxt.ts",
    "seo:validate": "tsx scripts/validateSeo.ts"
  },
  "dependencies": {
    "@types/react-window": "^1.8.8",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "cytoscape": "^3.28.1",
    "cytoscape-cose-bilkent": "^4.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-helmet-async": "^3.0.0",
    "react-router-dom": "^7.15.0",
    "react-window": "^2.2.7",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/cytoscape": "^3.19.16",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "tsx": "^4.7.1",
    "typescript": "^5.5.3",
    "vite": "^5.4.1",
    "zod": "^3.23.8"
  }
}
